{
  "name": "pyproc",
  "version": "0.0.9",
  "description": "브라우저 파이썬 프로세스 OS - 서버 없이 브라우저 탭에서 도는 진짜 런타임 파이썬(프로세스·병렬·복원 리액티브·머신 이미지). Real Python runtime in the browser tab: processes, parallelism, checkpoint/time-travel, portable .pymachine images.",
  "type": "module",
  "repository": { "type": "git", "url": "git+https://github.com/eddmpython/pyproc.git" },
  "homepage": "https://github.com/eddmpython/pyproc#readme",
  "bugs": { "url": "https://github.com/eddmpython/pyproc/issues" },
  "main": "index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": { "types": "./index.d.ts", "default": "./index.js" },
    "./runtime": "./src/runtime/runtime.js",
    "./reactive": "./src/capabilities/reactive.js",
    "./syscall-bridge": "./src/capabilities/syscallBridge.js",
    "./process-os": "./src/processOs/pyProc.js",
    "./worker": "./src/processOs/worker.js",
    "./browser-control-host": "./src/capabilities/browserControlHost.js"
  },
  "files": ["index.js", "index.d.ts", "src", "README.md", "README.ko.md", "LICENSE"],
  "scripts": {
    "test": "node tests/run.mjs",
    "test:browser": "node tests/browser/run.mjs",
    "test:examples": "node tests/browser/examples.mjs",
    "serve": "node examples/serve.mjs",
    "fetch:engine": "node scripts/fetchEngine.mjs"
  },
  "keywords": ["pyodide", "python", "browser", "wasm", "process", "parallel", "reactive", "runtime"],
  "license": "MPL-2.0"
}
