#!/bin/sh
# Block local branch creation/update outside main.
state="$1"

if [ "$state" != "prepared" ]; then
  exit 0
fi

allowed_ref="refs/heads/main"

while read old_sha new_sha ref_name
do
  case "$ref_name" in
    refs/heads/*)
      if [ "$ref_name" != "$allowed_ref" ]; then
        echo "blocked: this repository is main-only; refusing local branch ref $ref_name" >&2
        exit 1
      fi
      ;;
  esac
done

exit 0
