{
  "name": "pyproc",
  "version": "0.0.9",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "pyproc",
      "version": "0.0.9",
      "license": "MPL-2.0",
      "workspaces": [
        "packages/*"
      ],
      "bin": {
        "pyproc-assets": "scripts/assetManifest.mjs"
      }
    },
    "node_modules/@web-machine/browser": {
      "resolved": "packages/browser",
      "link": true
    },
    "node_modules/@web-machine/core": {
      "resolved": "packages/core",
      "link": true
    },
    "node_modules/@web-machine/guest-pyproc": {
      "resolved": "packages/guest-pyproc",
      "link": true
    },
    "node_modules/@web-machine/guest-v86": {
      "resolved": "packages/guest-v86",
      "link": true
    },
    "packages/browser": {
      "name": "@web-machine/browser",
      "version": "0.0.0",
      "license": "MPL-2.0",
      "dependencies": {
        "@web-machine/core": "0.0.0"
      }
    },
    "packages/core": {
      "name": "@web-machine/core",
      "version": "0.0.0",
      "license": "MPL-2.0"
    },
    "packages/guest-pyproc": {
      "name": "@web-machine/guest-pyproc",
      "version": "0.0.0",
      "license": "MPL-2.0",
      "peerDependencies": {
        "@web-machine/core": "0.0.0"
      }
    },
    "packages/guest-v86": {
      "name": "@web-machine/guest-v86",
      "version": "0.0.0",
      "license": "MPL-2.0",
      "peerDependencies": {
        "@web-machine/core": "0.0.0"
      }
    }
  }
}
